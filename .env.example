# Telegram bot token from BotFather
BOT_TOKEN=123456:your-telegram-bot-token

# Source chat id (chat A), usually -100... for supergroups/channels
SOURCE_CHAT_ID=-1001111111111

# Target chat id (chat B)
TARGET_CHAT_ID=-1002222222222

# Hashtag to trigger forwarding (#optional in value)
FORWARD_HASHTAG=#forward

# Optional but recommended in webhook mode (Vercel)
# Must match X-Telegram-Bot-Api-Secret-Token header
TELEGRAM_SECRET_TOKEN=replace-with-long-random-string

# Public webhook endpoint
WEBHOOK_URL=https://your-project.vercel.app/api/webhook

# Optional log verbosity for stdout/stderr JSON logs (debug|info|warn|error)
LOG_LEVEL=info
